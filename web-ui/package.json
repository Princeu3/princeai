{
  "name": "princeai-web",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --parallel --filter server --filter web dev",
    "dev:server": "pnpm -C server dev",
    "dev:web": "pnpm -C web dev",
    "start": "pnpm -C server start",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "esbuild"]
  }
}
